# Copy to `.env` and adjust. Vite only exposes vars prefixed with VITE_.
#
# Point this at any OpenAI-compatible chat-completions endpoint:
#   - Local (recommended for the minimal track): Ollama, LM Studio, vLLM
#   - Hosted: OpenAI, OpenRouter, or any compatible gateway
#
# SECURITY: in a pure browser app, VITE_LLM_API_KEY ships to the client. Only set
# it for a local endpoint or a key you're comfortable exposing. To keep a key
# secret, graduate to the full track and proxy through a backend.
# See references/llm-config.md.

VITE_LLM_BASE_URL=http://localhost:11434/v1
VITE_LLM_MODEL=llama3.1
# VITE_LLM_API_KEY=
